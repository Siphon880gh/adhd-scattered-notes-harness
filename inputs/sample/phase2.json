    "organized": {
        "tasks": [
            {
                "id": "t1",
                "title": "Compare nginx -t with reload / restart",
                "body": "Compare `nginx -t` (config test / validate) with the other commands:\n- `nginx -s reload` — reload config without dropping connections\n- restart (e.g. `systemctl restart nginx`) — full process restart\n\nWhat does `-t` actually validate vs what reload/restart do?\n\n(Shorthand: wtf = go find out)",
                "sources": [
                    "braindump.md:3"
                ],
                "tags": ["nginx"],
                "checked": false
            },
            {
                "id": "t2",
                "title": "SSH keys: authorized_keys + permissions",
                "body": "Copy pub to authorized_keys but ALSO check permissions 700/600 or it silently fails.",
                "sources": [
                    "braindump.md:5"
                ],
                "tags": ["ssh", "permissions"],
                "checked": true
            },
            {
                "id": "t3",
                "title": "UFW: open web ports without locking out SSH",
                "body": "ufw: allow 80/443 then enable; don't lock yourself out of 22.",
                "sources": [
                    "braindump.md:11"
                ],
                "tags": ["firewall", "ufw"],
                "checked": false
            },
            {
